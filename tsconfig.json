{
    "compilerOptions": {
        "rootDir": ".",
        "outDir": "./dist",

        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2023",
        "types": ["node"],
        "esModuleInterop": true,
        "ignoreDeprecations": "6.0",

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "strict": true,
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    },
    "include": ["**/*"]
}
